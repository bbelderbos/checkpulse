# Copy to .env for local dev (loaded by your shell, not the app) or set in Fly secrets.
DATABASE_PATH=checkpulse.db
SITE_ID=belderbos.dev
ALLOWED_ORIGIN=https://belderbos.dev
DASHBOARD_USER=admin
# Required (no default): the app refuses to start if unset. In prod use `fly secrets set`.
DASHBOARD_PASSWORD=
# Optional: path to GeoLite2-Country.mmdb for country breakdown.
GEOLITE_DB_PATH=
BIND=0.0.0.0
PORT=8080
